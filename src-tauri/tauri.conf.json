{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VJLED",
  "version": "0.1.0",
  "identifier": "com.yuta.vjled",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "VJLED - Control",
        "url": "/",
        "width": 1024,
        "height": 720
      },
      {
        "label": "output",
        "title": "VJLED - Output",
        "url": "/output.html",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["models/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good"
        ]
      }
    }
  }
}
